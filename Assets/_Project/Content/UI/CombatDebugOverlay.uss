.debug-container {
    position: absolute;
    top: 10px;
    left: 10px;
    flex-direction: column;
    background-color: rgba(0, 0, 0, 0.7);
    padding: 10px;
    border-radius: 5px;
    width: 250px;
}

.debug-label {
    font-size: 12px;
    color: #00ff00;
    margin-bottom: 5px;
    unity-font-style: bold;
}
